{
  "name": "json-cv",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "generate:types": "node scripts/generate-resume-types.mjs",
    "check:generated-types": "npm run generate:types && git diff --exit-code -- src/resume/domain/generated/resume.ts",
    "build": "npm run generate:types && astro check && astro build",
    "preview": "astro preview",
    "test": "vitest run --passWithNoTests",
    "test:pdf": "playwright test",
    "test:all": "npm test && npm run test:pdf && npm run build && npm run check:generated-types",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@astrojs/react": "6.0.1",
    "@codemirror/lang-json": "6.0.2",
    "@codemirror/lint": "6.9.7",
    "@codemirror/view": "6.43.6",
    "@jsonresume/schema": "1.3.0",
    "@uiw/react-codemirror": "4.25.11",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "astro": "7.0.9",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@playwright/test": "1.61.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "jsdom": "28.1.0",
    "json-schema-to-typescript": "15.0.4",
    "pdfjs-dist": "6.1.200",
    "prettier": "3.9.5",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
