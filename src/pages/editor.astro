---
import ResumeWorkspace from "../resume-editor/ui/ResumeWorkspace";
import "../resume-editor/ui/editor.css";
import "../resume-templates/template.css";
import "../shared/styles/global.css";
import { ROUTES } from "../shared/routes";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Edit JSON Resume locally and save an ATS-friendly PDF."
    />
    <meta property="og:title" content="JSON Resume Editor" />
    <meta
      property="og:description"
      content="Edit, preview, and export your JSON Resume to PDF. Works entirely in the browser — no data is sent to any server."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.toString()} />
    <link
      rel="icon"
      type="image/svg+xml"
      href={import.meta.env.BASE_URL + ROUTES.FAVICON}
    />
    <title>JSON Resume Editor</title>
  </head>
  <body>
    <ResumeWorkspace client:only="react" />
  </body>
</html>
